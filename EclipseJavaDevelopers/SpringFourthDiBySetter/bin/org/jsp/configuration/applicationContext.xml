<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    
    <bean class="org.jsp.model.Address" id="address">
    	<property name="houseNo" value="23"></property>
    	<property name="town" value="Angul"></property>
    	<property name="loc" value="Odisha"></property>
    </bean>
    
    <bean class="org.jsp.model.Student" id="student">
    	<property name="name" value="Ak" />
    	<property name="address" ref="address" />
    	<property name="marks" value="79.7" />
    </bean>
    
   

</beans>